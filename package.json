{
  "name": "kill-the-resume-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:lint": "npm --prefix web run lint",
    "web:typecheck": "npm --prefix web run typecheck",
    "web:start": "npm --prefix web run start",
    "backend:dev": "cd backend && go run ./cmd/server",
    "backend:test": "cd backend && go test ./...",
    "backend:build": "cd backend && go build ./cmd/server",
    "deploy:killer:frontend": "bash script/deploy-killer-frontend.sh",
    "deploy:killer:backend": "bash script/deploy-killer-backend.sh",
    "deploy:killer": "npm run deploy:killer:frontend && npm run deploy:killer:backend"
  }
}

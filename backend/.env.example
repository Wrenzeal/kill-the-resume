APP_ENV=development
SERVER_ADDR=:19304

# 默认连接本机 Docker 暴露出的 PostgreSQL 5432 端口。
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SCHEMA=kill_the_resume

# 生产环境必须替换为高强度随机密钥。
JWT_SECRET=change-me-kill-the-resume-production-secret
JWT_ISSUER=kill-the-resume
JWT_AUDIENCE=kill-the-resume-web
JWT_TTL_HOURS=168

# 请求体和认证限速。生产建议按实际流量收紧。
MAX_BODY_BYTES=1048576
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# 前端开发地址白名单，按需追加线上域名。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3301,http://127.0.0.1:3301,http://localhost:3302,http://127.0.0.1:3302

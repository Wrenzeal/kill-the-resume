APP_ENV=development
SERVER_ADDR=:19304

# 默认连接本机 Docker 暴露出的 PostgreSQL 5432 端口。
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SCHEMA=kill_the_resume

# 生产环境必须替换为高强度随机密钥。
JWT_SECRET=change-me-kill-the-resume-production-secret
JWT_ISSUER=kill-the-resume
JWT_AUDIENCE=kill-the-resume-web
JWT_TTL_HOURS=168

# 请求体和认证限速。生产建议按实际流量收紧。
MAX_BODY_BYTES=1048576
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# 前端来源白名单。Vercel 未绑定自定义域名前可保留 https://*.vercel.app；绑定域名后建议追加精确域名。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3301,http://127.0.0.1:3301,http://localhost:3302,http://127.0.0.1:3302,https://*.vercel.app

# 机会雷达真实岗位数据源。默认使用 Remotive 公开 API；按其官方建议不要高频请求，默认每个搜索指纹 6 小时按需同步一次。
JOB_RADAR_SYNC_ENABLED=true
JOB_RADAR_SYNC_INTERVAL_MINUTES=360
JOB_RADAR_HTTP_TIMEOUT_SECONDS=10
JOB_RADAR_MAX_RESULTS=80
JOB_RADAR_REMOTIVE_URL=https://remotive.com/api/remote-jobs

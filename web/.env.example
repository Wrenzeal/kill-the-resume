# 本地开发可留空；localhost 会请求 http://127.0.0.1:19304/api/v1。
# 远程 HTTP 开发访问会按当前页面主机推导 http://<server-ip>:19304/api/v1。
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:19304/api/v1

# Vercel/HTTPS 生产推荐直接请求后端 API 子域，浏览器 Network 中应显示 api.killer.wrenzeal.top。
NEXT_PUBLIC_API_BASE_URL=https://api.killer.wrenzeal.top/api/v1

# 可选：如果需要保留 Vercel 同源 rewrite，也可以设置该变量；当前 API client 会优先使用上方直接 API 地址。
# KTR_BACKEND_ORIGIN=https://api.killer.wrenzeal.top
